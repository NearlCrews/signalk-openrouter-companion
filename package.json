{
  "name": "signalk-openrouter-companion",
  "version": "0.3.0",
  "description": "OpenRouter-powered analyzers for Signal K (maintenance, health, alerts, aging, drift). Requires a paid OpenRouter API key; LLM calls are billed per token. Per-day call cap enforced.",
  "main": "dist/index.js",
  "type": "module",
  "files": ["dist/", "public/", "assets/icons/", "README.md", "LICENSE", "CHANGELOG.md"],
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-utility",
    "signalk-category-notifications",
    "openrouter",
    "llm",
    "ai",
    "marine",
    "maintenance"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "OpenRouter Companion",
    "appIcon": "./assets/icons/icon-192.png"
  },
  "engines": { "node": ">=20.18" },
  "license": "Apache-2.0",
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com",
    "url": "https://github.com/NearlCrews"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-openrouter-companion.git"
  },
  "homepage": "https://github.com/NearlCrews/signalk-openrouter-companion#readme",
  "bugs": { "url": "https://github.com/NearlCrews/signalk-openrouter-companion/issues" },
  "peerDependencies": { "@signalk/server-api": ">=2.24.0 <3" },
  "dependencies": { "croner": "^10.0.1" },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@signalk/server-api": "^2.24.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "esbuild": "^0.28.0",
    "esbuild-loader": "^4.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.0"
  },
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:bundle && npm run build:panel",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:bundle": "node esbuild.config.mjs",
    "build:panel": "webpack --config webpack.config.cjs",
    "clean": "rm -rf dist public",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "security-audit": "npm audit --audit-level=moderate",
    "validate": "npm run type-check && npm run lint && npm run test:run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run type-check && npm run lint && npm run test && npm run build"
  }
}
