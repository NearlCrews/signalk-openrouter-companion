{
  "name": "signalk-openrouter-companion",
  "version": "0.6.1",
  "description": "OpenRouter-powered LLM analyzers for Signal K: plain-prose engine, battery, and weather reports. OpenRouter API key required.",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/",
    "public/",
    "assets/icons/",
    "assets/screenshots/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-utility",
    "signalk-category-notifications",
    "openrouter",
    "llm",
    "marine"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "OpenRouter Companion",
    "appIcon": "./assets/icons/icon-192.png",
    "screenshots": [
      "./assets/screenshots/panel-overview.png",
      "./assets/screenshots/panel-analyzers.png"
    ],
    "recommends": [
      "signalk-virtual-weather-sensors",
      "signalk-nmea2000-emitter-cannon"
    ]
  },
  "engines": {
    "node": ">=20.18"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com",
    "url": "https://github.com/NearlCrews"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-openrouter-companion.git"
  },
  "homepage": "https://github.com/NearlCrews/signalk-openrouter-companion#readme",
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-openrouter-companion/issues"
  },
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/nearlcrews"
  },
  "peerDependencies": {
    "@signalk/server-api": ">=2.24.0 <3"
  },
  "dependencies": {
    "croner": "^10.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@signalk/server-api": "2.28.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "esbuild-loader": "^4.5.0",
    "react": "^19.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.0"
  },
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:bundle && npm run build:panel",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:bundle": "node esbuild.config.mjs",
    "build:panel": "webpack --config webpack.config.cjs",
    "clean": "node -e \"const fs=require('node:fs');for(const d of ['dist','public'])fs.rmSync(d,{recursive:true,force:true})\"",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit && tsc -p tsconfig.tests.json && tsc -p tsconfig.panel.json",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "security-audit": "npm audit --audit-level=moderate",
    "validate": "npm run type-check && npm run lint && npm run test:run",
    "prepublishOnly": "npm run type-check && npm run lint && npm run test && npm run build"
  }
}
